# Server
PORT=4000

# MongoDB
MONGODB_URI=mongodb+srv://<user>:<password>@cluster.mongodb.net/cms-academy

# JWT
JWT_SECRET=your-super-secret-jwt-key-change-this

# Super Admin bootstrap — comma-separated emails auto-promoted to superAdmin on login/OTP-verify
SUPER_ADMIN_EMAILS=your-email@example.com

# Nodemailer (Gmail)
NODEMAILER_USER=your-email@gmail.com
NODEMAILER_PASS=your-app-password

# SSLCommerz
SSLCOMERZ_STORE_ID=your-store-id
SSLCOMERZ_STORE_PASSWORD=your-store-password
SSLCOMERZ_IS_LIVE=false

# Cloudinary
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret

# Firebase Admin
FIREBASE_PROJECT_ID=your-project-id
FIREBASE_CLIENT_EMAIL=your-client-email
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
FIREBASE_STORAGE_BUCKET=your-bucket.appspot.com

# Gemini (Google AI Studio free API key) — powers the site's AI chat assistant
# Get a free key at https://aistudio.google.com/apikey
GEMINI_API_KEY=your-gemini-api-key
GEMINI_MODEL=gemini-flash-latest

# Frontend URL (for CORS & redirects)
FRONTEND_URL=http://localhost:3000

# Backend's own public URL (used for SSLCommerz success/fail/cancel callback routes,
# which are Express routes on this server, not on the frontend)
BACKEND_URL=http://localhost:4000
