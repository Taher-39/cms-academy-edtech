# Backend API base URL (the deployed Express backend, e.g. https://cms-academy-api.vercel.app)
NEXT_PUBLIC_API_URL=http://localhost:4000

# Payment mode: "manual" = bKash/Nagad/Rocket only, "sslcommerz" = SSLCommerz + manual both
NEXT_PUBLIC_PAYMENT_MODE=manual

# Firebase (client-side - for Google Sign-In popup)
NEXT_PUBLIC_FIREBASE_API_KEY=your-firebase-api-key
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your-project-id
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=your-project.appspot.com
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=your-sender-id
NEXT_PUBLIC_FIREBASE_APP_ID=your-app-id
NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID=your-measurement-id

# WhatsApp contact number (country code + number, no spaces or +)
NEXT_PUBLIC_WHATSAPP_NUMBER=8801516559515
